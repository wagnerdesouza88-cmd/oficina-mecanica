# Normaliza fins de linha para LF em todos os arquivos de texto
* text=auto eol=lf

# Arquivos que devem sempre ser LF
*.js     text eol=lf
*.jsx    text eol=lf
*.ts     text eol=lf
*.tsx    text eol=lf
*.css    text eol=lf
*.html   text eol=lf
*.json   text eol=lf
*.prisma text eol=lf
*.sql    text eol=lf
*.md     text eol=lf
*.toml   text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf
*.sh     text eol=lf

# Binários (sem conversão)
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.ico    binary
*.svg    text eol=lf
